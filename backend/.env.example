# Copy this file to .env and fill in your values. .env is gitignored.
# Get a free Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Models
# gemini-3.5-flash is newest but often 503s on free tier; 2.5-flash is stable.
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-2
EMBED_DIM=768

# Retrieval
TOP_K=6

# Paths (relative to the backend/ project root)
INDEX_PATH=data/index/embeddings.json
CVS_DIR=data/cvs
